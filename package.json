{
  "name": "@omb/website",
  "version": "0.1.0",
  "private": true,
  "description": "Oh My Browser marketing website (Next.js 14 App Router + next-intl)",
  "scripts": {
    "dev": "next dev --webpack -p 4174",
    "dev:watch": "npx --yes nodemon --quiet --watch next.config.mjs --watch ../../.env --watch tailwind.config.ts --watch postcss.config.mjs --ext mjs,js,ts,env --exec 'next dev --webpack -p 4174'",
    "build": "next build --webpack",
    "start": "next start -p 4174",
    "typecheck": "tsc --noEmit",
    "keyword-check": "tsx scripts/keyword-banlist-check.ts",
    "linkinator": "linkinator http://localhost:4174 --recurse --skip 'localhost|127.0.0.1' --silent"
  },
  "dependencies": {
    "@fontsource/inter": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@sentry/browser": "^8.0.0",
    "next": "^16.2.4",
    "next-intl": "^4.11.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.5.0"
  }
}
